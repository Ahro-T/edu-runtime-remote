# PostgreSQL connection string
# In Docker Compose, use the service name 'postgres' as the host
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/edu_runtime

# vLLM OpenAI-compatible API base URL (remote)
VLLM_URL=https://llm.agentic-ai-gist.org

# Model served by the remote vLLM endpoint
VLLM_MODEL=google/gemma-4-26B-A4B-it

# Cloudflare Access service token (required if vLLM endpoint is behind CF Access)
CF_CLIENT_ID=
CF_CLIENT_SECRET=

# Absolute path to the compiled wiki-vault directory (inside the container)
# Mounted via docker-compose volume: ./wiki-vault:/app/wiki-vault
# This is where ObsidianContentRepository reads concept nodes and templates from
VAULT_PATH=/app/wiki-vault

# OpenClaw Gateway URL (Runtime API URL for OpenClaw to call)
# Defaults to http://localhost:3100 if not set
OPENCLAW_GATEWAY_URL=http://localhost:3100

# OpenClaw Gateway Discord credentials (used by the openclaw Docker service)
OPENCLAW_DISCORD_TOKEN=your-openclaw-bot-token
OPENCLAW_DISCORD_GUILD_ID=your-guild-id

# Port the OpenClaw Gateway listens on (default 3100)
OPENCLAW_GATEWAY_PORT=3100

# Logging level: trace | debug | info | warn | error | fatal
# Defaults to 'info' if not set
LOG_LEVEL=info

# HTTP port the Fastify server listens on
# Defaults to 3000 if not set
PORT=3000
