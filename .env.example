# PostgreSQL connection string
# In Docker Compose, use the service name 'postgres' as the host
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/edu_runtime

# Absolute path to the compiled wiki-vault directory (inside the container)
# Mounted via docker-compose volume: ./wiki-vault:/app/wiki-vault
VAULT_PATH=/app/wiki-vault

# vLLM endpoint — used by OpenClaw for Gemma 4 inference (not by Runtime)
VLLM_URL=https://llm.agentic-ai-gist.org
VLLM_MODEL=google/gemma-4-27b-it

# OpenClaw Gateway Discord credentials
OPENCLAW_DISCORD_TOKEN=your-discord-bot-token
OPENCLAW_DISCORD_GUILD_ID=your-guild-id

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# HTTP port the Fastify server listens on
PORT=3000
